PORT=3000
NODE_ENV=development

# PostgreSQL — paste your real URL here (Render: External Database URL)
# If password has special chars (@, #, etc.), URL-encode them in the connection string.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/notes_db

# Set true when connecting to Render Postgres from local machine
DATABASE_SSL=false

JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# About endpoint — update before submission
ABOUT_NAME=Your Name
ABOUT_EMAIL=your.email@example.com
